datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  hashedPassword  String
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions             Session[]
  emailVerification    EmailVerificationToken[]
  passwordResets       PasswordResetToken[]
  organizationMembers  OrganizationMembership[]
  settings             UserSettings?
  tasks                Task[]
  reminders            Reminder[]
  bookmarks            Bookmark[]
  notes                Note[]
  attachments          Attachment[]
  connectionStatuses   ConnectionStatus[]
  gmailConnections     GmailConnection[]
  linkedInConnections  LinkedInConnection[]
  googleDocsConnections GoogleDocsConnection[]
  googleDriveConnections GoogleDriveConnection[]
  slackConnections     SlackConnection[]
  jiraConnections      JiraConnection[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ipHash    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now())

  members OrganizationMembership[]
}

model OrganizationMembership {
  id     String @id @default(uuid())
  orgId  String
  userId String
  role   String @default("member")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model UserSettings {
  id              String @id @default(uuid())
  userId          String @unique
  jsonPreferences String @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id          String   @id @default(uuid())
  actorUserId String?
  orgId       String?
  type        String
  metadata    String?
  createdAt   DateTime @default(now())
}

// Module specific generic tables
model Task {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  sourceRef   String?  // e.g. "gmail:thread123"
  sourceUrl   String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  title       String?
  sourceRef   String?
  time        DateTime
  message     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id          String   @id @default(uuid())
  userId      String
  title       String
  url         String
  metadata    String?
  sourceRef   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id          String   @id @default(uuid())
  userId      String
  content     String
  sourceUrl   String?
  sourceRef   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attachment {
  id          String   @id @default(uuid())
  userId      String
  filename    String
  size        Int
  mimeType    String
  storageKey  String
  url         String?
  sourceRef   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectionStatus {
  id            String   @id @default(uuid())
  userId        String
  profileUrl    String
  profileName   String
  status        String   // e.g., "pending", "connected", "none"
  lastCheckedAt DateTime @default(now())
  sourceRef     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GmailConnection {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String?
  refreshToken String?
  emailAddress String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInConnection {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String?
  refreshToken String?
  profileId    String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleDocsConnection {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String?
  refreshToken String?
  accountId    String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleDriveConnection {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String?
  refreshToken String?
  accountId    String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SlackConnection {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String?
  workspaceId  String?
  workspaceName String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JiraConnection {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String?
  refreshToken String?
  domain       String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
